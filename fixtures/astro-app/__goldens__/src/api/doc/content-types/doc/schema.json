{
  "kind": "collectionType",
  "collectionName": "docs",
  "info": {
    "singularName": "doc",
    "pluralName": "docs",
    "displayName": "Doc"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "order": {
      "type": "integer"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "guide",
        "reference"
      ],
      "required": true
    },
    "publishedOn": {
      "type": "datetime",
      "required": true
    }
  }
}
