{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "body": {
      "type": "richtext"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "draft",
        "published"
      ]
    },
    "views": {
      "type": "integer"
    },
    "featured": {
      "type": "boolean"
    },
    "releaseDate": {
      "type": "datetime"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ],
      "required": true
    },
    "gallery": {
      "type": "media",
      "multiple": true
    },
    "hero": {
      "type": "component",
      "repeatable": false,
      "component": "sections.hero"
    },
    "faqs": {
      "type": "component",
      "repeatable": true,
      "component": "sections.faq"
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "sections.hero",
        "sections.cta"
      ]
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::author.author"
    }
  }
}
