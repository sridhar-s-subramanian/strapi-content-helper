{
  "name": "strapi-plugin-content-helper",
  "version": "0.1.0",
  "description": "Strapi v5 plugin wrapping the content-helper engine (dev-mode sync + admin preview)",
  "keywords": ["strapi", "strapi-plugin", "content-type", "codegen", "nextjs", "astro"],
  "license": "MIT",
  "author": "Sivasubramanian Rajamanickam",
  "homepage": "https://github.com/sridhar-s-subramanian/strapi-plugin-content-helper/tree/main/packages/plugin#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sridhar-s-subramanian/strapi-plugin-content-helper.git",
    "directory": "packages/plugin"
  },
  "bugs": {
    "url": "https://github.com/sridhar-s-subramanian/strapi-plugin-content-helper/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./strapi-server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm -w run build && pnpm -w run test"
  },
  "dependencies": {
    "@swamp-crocodile/content-helper-core": "workspace:*"
  },
  "peerDependencies": {
    "@strapi/strapi": "^5.0.0",
    "@strapi/design-system": "^2.0.0",
    "react": "^18.0.0"
  },
  "peerDependenciesMeta": {
    "@strapi/strapi": { "optional": true },
    "@strapi/design-system": { "optional": true },
    "react": { "optional": true }
  },
  "strapi": {
    "kind": "plugin",
    "name": "content-helper",
    "displayName": "Content Helper",
    "description": "Generate Strapi content models from Next.js / Astro code"
  }
}
